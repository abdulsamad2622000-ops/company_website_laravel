APP_NAME=NovaStackHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://novastackhub.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ─────────────────────────────────────────────────────────────
# Database (MySQL) — apni VPS credentials yahan daalein
# ─────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=novastackhub
DB_USERNAME=novastack
DB_PASSWORD=your_db_password_here

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=database

# ─────────────────────────────────────────────────────────────
# Mail — Brevo (Sendinblue) SMTP
# Brevo dashboard → SMTP & API → SMTP credentials se values lein.
# MAIL_USERNAME = aapka Brevo login email
# MAIL_PASSWORD = Brevo "SMTP key" (account password NAHI)
# ─────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your_brevo_login@example.com
MAIL_PASSWORD=your_brevo_smtp_key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@novastackhub.com"
MAIL_FROM_NAME="${APP_NAME}"

# Naye leads ki notification yahan aayegi. Khali chhoda to MAIL_FROM_ADDRESS pe jayegi.
LEAD_NOTIFY_TO=info@novastackhub.com
